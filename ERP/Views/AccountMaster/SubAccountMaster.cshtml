@model BObject.AccountModel.SubAccountMaster
@{
    ViewBag.Title = "Sub Account Master";
}
<!-- CSS & Scripts -->
<link href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" rel="stylesheet" />
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet" />

<style>
    .btn-animated {
        transition: all 0.3s ease-in-out;
        border-radius: 8px;
        font-weight: 500;
    }

        .btn-animated:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 16px rgba(0, 0, 0, 0.1);
        }

    .btn-gradient {
        background: linear-gradient(45deg, #1e90ff, #007bff);
        border: none;
        color: white;
    }

    .form-section-title {
        font-size: 1.25rem;
        font-weight: 600;
        color: #003366;
        margin-top: 25px;
        margin-bottom: 15px;
    }

    .form-control {
        border-radius: 6px;
    }

    label {
        font-weight: 500;
    }
</style>

<div class="container-fluid py-4">
    <h2 style="background-color: aliceblue; text-align: center;">@ViewBag.Title</h2>
    <hr />
    @using (Html.BeginForm("SubAccountMaster", "AccountMaster", FormMethod.Post, new { id = "FormSubmit", name = "FormSubmit", autocomplete = "off" }))
    {
        <hr />
        <!-- Account Master Fields -->
        <div class="row g-3">
            <div class="col-md-3">
                <label>Sub Account Code:</label>
                <input type="text" class="form-control" id="txtAccountCode" name="txtAccountCode" value="@Model.SAM_SubCode" />
            </div>
            <div class="col-md-3">
                <label>Sub Account Name:</label>
                <input type="text" class="form-control" id="txtAccountName" name="txtAccountName" value="@Model.SAM_SubLongDesc" />
            </div>
            <div class="col-md-3">
                <label>Sub Account Desc:</label>
                <input type="text" class="form-control" id="txtAccountDesc" name="txtAccountDesc" value="@Model.SAM_SubDescription" />
            </div>
            <div class="col-md-3">
                <label>Account:</label>
                <select id="ddlAccount" name="ddlAccount" class="form-control">
                    <option value="0">Select</option>
                    @foreach (var BM in Model.AccountMasterList)
                    {
                        <option value="@BM.AM_AccountId" @(Model.SAM_AccountId == BM.AM_AccountId ? "selected" : "")>
                            @BM.AM_AccDescription
                        </option>
                    }
                </select>
            </div>
        </div>
        <hr />
        <!-- Address Details -->
        <div class="form-section-title">Address Details</div>
        <div class="row g-3">
            <div class="col-md-3">
                <label>Address Line 1:</label>
                <input type="text" class="form-control" id="txtAddress1" name="txtAddress1" value="@Model.SAM_Address1" />
            </div>
            <div class="col-md-3">
                <label>Address Line 2:</label>
                <input type="text" class="form-control" id="txtAddress2" name="txtAddress2" value="@Model.SAM_Address2" />
            </div>
            <div class="col-md-3">
                <label>Address Line 3:</label>
                <input type="text" class="form-control" id="txtAddress3" name="txtAddress3" value="@Model.SAM_Address3" />
            </div>
            <div class="col-md-3">
                <label>Address Line 4:</label>
                <input type="text" class="form-control" id="txtAddress4" name="txtAddress4" value="@Model.SAM_Address4" />
            </div>
        </div>
        <hr />
        <!-- Communication Details -->
        <div class="form-section-title">Communication Details</div>
        <div class="row g-3">
            <div class="col-md-3">
                <label>Org Ph:</label>
                <input type="text" class="form-control" id="txtOPhone" name="txtOPhone" value="@Model.SAM_OPhone" />
            </div>
            <div class="col-md-3">
                <label>Fax:</label>
                <input type="text" class="form-control" id="txtFAX" name="txtFAX" value="@Model.SAM_FAX" />
            </div>
            <div class="col-md-3">
                <label>Email:</label>
                <input type="email" class="form-control" id="txtEmail" name="txtEmail" value="@Model.SAM_Email" />
            </div>
            <div class="col-md-3">
                <label>Website:</label>
                <input type="text" class="form-control" id="txtWebsite" name="txtWebsite" value="@Model.SAM_Website" />
            </div>
            <div class="col-md-3">
                <label>PAN:</label>
                <input type="text" class="form-control" id="txtPAN" name="txtPAN" value="@Model.SAM_PAN" />
            </div>
            <div class="col-md-3">
                <label>CST:</label>
                <input type="text" class="form-control" id="txtCST" name="txtCST" value="@Model.SAM_CST" />
            </div>
            <div class="col-md-3">
                <label>SST:</label>
                <input type="text" class="form-control" id="txtSST" name="txtSST" value="@Model.SAM_SST" />
            </div>
        </div>

        <!-- Message Display -->
        <div class="row mt-4">
            <div class="col-md-12 text-end">
                <span class="text-success fw-bold">@ViewBag.Message</span>
            </div>
        </div>

        <!-- Buttons -->
        <hr />
        <div class="row mt-4">
            <div class="col-md-6">
                <a href="/AccountMaster/SubAccountMasterList" class="btn btn-link">
                    <img src="~/Logo/back.png" width="20" height="20" /> Back To List
                </a>
            </div>
            <div class="col-md-6 text-end">
                <button type="button" id="btnSubmit" class="btn btn-animated btn-gradient me-2" onclick="SaveData();">
                    <i class="bi bi-save"></i> Submit
                </button>

                <input type="button" id="btnReset" class="btn btn-default" value="Reset" onclick="javascript:Reset();">
            </div>
        </div>
    }
</div>

<script type="text/javascript">

    function SaveData() {
        document.getElementById("FormSubmit").submit();
    }
     $(document).ready(function () {
            @if (TempData["Success"] != null)
            {
                <text>
                    toastr.success("@TempData["Success"]");
                    setTimeout(function () {
                        window.location.href = "/AccountMaster/SubAccountMasterList";
                    }, 2000); // Redirect after 2 seconds
                </text>
            }
        });
</script>