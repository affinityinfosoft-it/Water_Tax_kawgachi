@model BObject.AccountModel.SubAccountMaster
@{
    ViewBag.Title = "Sub Account Master List";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<div class="page-body-height">
    @using (Html.BeginForm("SubAccountMasterList", "AccountMaster", new { ReturnUrl = ViewBag.ReturnUrl }, FormMethod.Post, new { @class = "", role = "form", autocomplete = "off" }))
    {
        <h2 style="background-color: aliceblue; text-align: center;">@ViewBag.Title</h2>
        <div class="clearfix mb-3">
            @if ((bool)Session["CanAdd"] == true)
            {
                <a href="/AccountMaster/SubAccountMaster" class="btn btn-primary float-end" style="text-decoration:none;">ADD</a>
            }
        </div>
        <hr />
        if ((bool)Session["CanView"] == true)
        {
            <div class="clearfix"></div>
            <div class="row">
                <div class="col-sm-12 col-xl-12 col-md-12 table-responsive">
                    <table id="table" data-toggle="table" data-pagination="true" data-search="true" data-show-pagination-switch="true" data-show-refresh="true" data-key-events="true" data-show-toggle="true" data-resizable="true" data-cookie="true" data-cookie-id-table="saveId" data-show-export="true" data-click-to-select="true" data-toolbar="#toolbar">
                        <thead>
                            <tr>
                                <th data-checkbox="true"></th>
                                <th>Sl.</th>
                                <th>Sub Account Name</th>
                                <th>Sub Account Code</th>
                                <th>Ph NO</th>
                                <th>Email</th>
                                <th>Address</th>
                                <th>Edit</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{ int i = 1; }
                            @foreach (var item in Model.SubAccountMasterList)
                            {
                                <tr>
                                    <td></td>
                                    <td>@i</td>
                                    <td>@item.SAM_SubLongDesc</td>
                                    <td>@item.SAM_SubCode</td>
                                    <td>@item.SAM_OPhone</td>
                                    <td>@item.SAM_Email</td>
                                    <td>@item.SAM_Address1</td>

                                    @if ((bool)Session["CanEdit"] == true)
                                    {
                                        <td>
                                            <a href="/AccountMaster/SubAccountMaster?Id=@item.SAM_SubId" style="text-decoration:none;">
                                                <img src="~/Logo/Edit.png" width="30" height="30" title="Edit" />
                                            </a>
                                        </td>
                                    }
                                    else
                                    {
                                        <td>
                                            <a href="javascript:void(0)" style="text-decoration:none;">
                                                <img src="~/Logo/Edit.png" width="30" height="30" title="Edit Not Authorized" />
                                            </a>
                                        </td>
                                    }

                                    @*@if ((bool)Session["CanDelete"] == true)
                                        {
                                            <td>
                                                <a href="javascript:void(0)" onclick="DeleteArea(@item.SAM_SubId);" style="text-decoration:none;">
                                                    <img src="~/Logo/Delete.png" width="30" height="30" title="Delete" />
                                                </a>
                                            </td>
                                        }
                                        else
                                        {
                                            <td>
                                                <a href="javascript:void(0)" style="text-decoration:none;">
                                                    <img src="~/Logo/Delete.png" width="30" height="30" title="Delete Not Authorized" />
                                                </a>
                                            </td>
                                        }*@


                                </tr>
                                i = i + 1;
                            }

                        </tbody>
                    </table>
                </div>
            </div> }
        else
        {
            <div class="alert-danger">
                <h3>You Are Not Authorize....................!</h3>
            </div>}


        @Scripts.Render("~/bundles/jquery")
        <script src="~/Scripts/data-table/bootstrap-table.js"></script>
    }
</div>