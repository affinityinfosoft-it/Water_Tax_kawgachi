@model BObject.AccountModel.SubAccountMaster
@{
    ViewBag.Title = "Account Master";
}
<link href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" rel="stylesheet" />
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet" />

<style>
    <style >
    .btn-animated {
        transition: all 0.3s ease-in-out;
        box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
        border-radius: 12px;
        font-weight: 500;
    }

    .btn-animated:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 16px rgba(0, 0, 0, 0.15);
    }

    .btn-animated i {
        transition: transform 0.3s ease-in-out;
        margin-right: 6px;
    }

    .btn-animated:hover i {
        transform: rotate(360deg);
    }

    .btn-gradient {
        background: linear-gradient(45deg, #1e90ff, #007bff);
        border: none;
        color: white;
    }

    .btn-outline-secondary:hover {
        background-color: #f1f1f1;
        color: #333;
    }
</style>
<div class="page-body-height">
    <h2>@ViewBag.Title</h2>
    <hr />
    @using (Html.BeginForm("OpeningBalanceSubAccountMaster", "AccountMaster", new { ReturnUrl = ViewBag.ReturnUrl }, FormMethod.Post, new { id = "FormSubmit", name = "FormSubmit", @class = "", role = "form", autocomplete = "off" }))
    {

        <input id="btnAddEnable" name="btnAddEnable" type="hidden" value="0" />
        <input id="btnEditEnable" name="btnEditEnable" type="hidden" value="0" />
        <input id="btnViewEnable" name="btnViewEnable" type="hidden" value="0" />
        <input id="btnDeleteEnable" name="btnDeleteEnable" type="hidden" value="0" />
        <input type="hidden" id="hdnCollegeId" value="@ViewBag.CollegeId" />
        <input type="hidden" id="hdnSessionId" value="@ViewBag.SessionId" />


        <input id="hdnAccountId" name="hdnAccountId" type="hidden" value="@Model.SubAccountMasterList.FirstOrDefault().AM_AccountId" />
        @*<input id="hdnAccountOpId" name="hdnAccountOpId" type="hidden" value="@Model.AM_AccountOpId" />
            <input id="hdnAccountCode" name="hdnAccountCode" type="hidden" value="@Model.AM_AccountCode" />*@
        <input id="hdnRollId" name="hdnRollId" type="hidden" value="@ViewBag.RoleId" />
        <input id="hdnPaymentId" name="hdnPaymentId" type="hidden" value="0" />
        <div class="row">
            <div class="col-md-11">
            </div>
            <div class="col-md-1">
                @*<a id="btnBack" class="btnBack" href="@Url.Action("studentlist", "home")">Back<i class="ui-icon ui-icon-arrowreturnthick-1-w"></i></a>*@
            </div>
        </div>
        @*<div class="clearfix"></div>*@
        <div class="row">


            <div class="col-lg-3">
                <div class="form-group">
                    <label for="ddlAccount">Account:</label>
                    <input id="ddlAccount" name="ddlAccount" class="form-control" value="@Model.SubAccountMasterList.FirstOrDefault().AM_AccountCode" readonly />

                </div>
            </div>
            <div class="col-lg-3">
                <div class="form-group">
                    <label for="ddlAccountDesc">Account Desc:</label>
                    <input id="ddlAccountDesc" name="ddlAccountDesc" class="form-control" value="@Model.SubAccountMasterList.FirstOrDefault().AM_AccDescription" readonly />

                </div>
            </div>


        </div>
        <div class="row">
            <h2 class="enquiry-s-b-information">Opening Balance Details:</h2>
        </div>
        <div class="row">
            <div class="col-lg-12">

                <table id="tblSubject" class="table  table-striped table-responsive table-bordered mGrid">
                    <thead>
                        <tr>
                            <th class="align-center" hidden="hidden"><strong>SubID</strong></th>
                            <th class="align-center"><strong>Sub A/C Code</strong></th>

                            <th class="align-center"><strong>Sub A/C Description</strong></th>

                            <th class="align-center"> <strong>Opening Balance</strong></th>
                            <th class="align-center"> <strong>Type</strong></th>
                        </tr>
                    </thead>
                    <tbody id="tBody">


                        @{
                            int Index = 0;
                            foreach (var VM in Model.SubAccountMasterList)
                            {
                                Index = Index + 1;
                                <tr>
                                    <td class="align-center" hidden="hidden"><input type='hidden' name='hdnSubAccountId_@Index' id='hdnSubAccountId_@Index' value='@VM.SAM_AccountId' /></td>
                                    <td class="align-center"><input name='hdnSubAccountCode_@Index' id='hdnSubAccountCode_@Index' value='@VM.SAM_SubCode' class="form-control" /></td>
                                    <td class="align-center"><input name='hdnSubDescription_@Index' id='hdnSubDescription_@Index' value='@VM.SAM_SubDescription' class="form-control" /></td>


                                    <td><input id="txtOpeningBalance_@Index" name="txtOpeningBalance_@Index" class="form-control numeric" value="@VM.SAM_OpeningBalance" /></td>

                                    <td><select id="OpeningType_@Index" name="OpeningType_@Index" style="width: 300px;" class="form-control"><option value="C">Credit</option><option value="D">Debit</option></select></td>
                                </tr>

                            }
                        }



                    </tbody>

                </table>

            </div>
        </div>


        <div class="row">
            <div class="col-lg-6">
                <div class="form-group">
                    <input type="hidden" id="hdnValidation" name="hdnValidation" value="@ViewBag.MessageId" />
                    <div id="divValidation"></div>
                    <div id="divMessage" style="text-align:right;margin-top:25px;font-size: 16px;color: green;font-weight: bold;text-transform: capitalize">@ViewBag.Message</div>
                </div>
            </div>


        </div>
        <hr />
        <hr />
        <div class="row mt-4">
            <a href="/AccountMaster/OpeningBalanceMasterList">
                <img src="~/Logo/back.png" width="20" height="20" />
                Back To List
            </a>

            <div class="row mt-4">
                <div class="col-12 text-end">
                    <button type="button" id="btnSubmit" class="btn btn-animated btn-gradient me-2" onclick="SaveData();">
                        <i class="bi bi-save"></i> Save
                    </button>
                    <button type="button" id="btnReset" class="btn btn-animated btn-outline-secondary" onclick="location.reload();">
                        <i class="bi bi-arrow-clockwise"></i> Reset
                    </button>
                </div>
            </div>

        </div>

    }
</div>

