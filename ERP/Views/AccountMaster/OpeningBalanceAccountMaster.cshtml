@model BObject.AccountModel.AccountMaster
@{
    ViewBag.Title = "Account Master";
}
<link href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" rel="stylesheet" />
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet" />

<style>
    <style >
    .btn-animated {
        transition: all 0.3s ease-in-out;
        box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
        border-radius: 12px;
        font-weight: 500;
    }

    .btn-animated:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 16px rgba(0, 0, 0, 0.15);
    }

    .btn-animated i {
        transition: transform 0.3s ease-in-out;
        margin-right: 6px;
    }

    .btn-animated:hover i {
        transform: rotate(360deg);
    }

    .btn-gradient {
        background: linear-gradient(45deg, #1e90ff, #007bff);
        border: none;
        color: white;
    }

    .btn-outline-secondary:hover {
        background-color: #f1f1f1;
        color: #333;
    }
</style>
<div class="page-body-height">
    <h2>@ViewBag.Title</h2>
    <hr />
    @using (Html.BeginForm("OpeningBalanceAccountMaster", "AccountMaster", new { ReturnUrl = ViewBag.ReturnUrl }, FormMethod.Post, new { id = "FormSubmit", name = "FormSubmit", @class = "", role = "form", autocomplete = "off" }))
    {

        <input id="btnAddEnable" name="btnAddEnable" type="hidden" value="0" />
        <input id="btnEditEnable" name="btnEditEnable" type="hidden" value="0" />
        <input id="btnViewEnable" name="btnViewEnable" type="hidden" value="0" />
        <input id="btnDeleteEnable" name="btnDeleteEnable" type="hidden" value="0" />
        <input type="hidden" id="hdnCollegeId" value="@ViewBag.CollegeId" />
        <input type="hidden" id="hdnSessionId" value="@ViewBag.SessionId" />


        <input id="hdnAccountId" name="hdnAccountId" type="hidden" value="@Model.AM_AccountId" />
        <input id="hdnAccountOpId" name="hdnAccountOpId" type="hidden" value="@Model.AM_AccountOpId" />
        <input id="hdnAccountCode" name="hdnAccountCode" type="hidden" value="@Model.AM_AccountCode" />
        <input id="hdnRollId" name="hdnRollId" type="hidden" value="@ViewBag.RoleId" />
        <input id="hdnPaymentId" name="hdnPaymentId" type="hidden" value="0" />
        <div class="row">
            <div class="col-md-11">
            </div>
            <div class="col-md-1">
                @*<a id="btnBack" class="btnBack" href="@Url.Action("studentlist", "home")">Back<i class="ui-icon ui-icon-arrowreturnthick-1-w"></i></a>*@
            </div>
        </div>
        @*<div class="clearfix"></div>*@
        <div class="row">


            <div class="col-lg-3">
                <div class="form-group">
                    <label for="ddlAccount">Account:</label>
                    <input id="ddlAccount" name="ddlAccount" class="form-control" value="@Model.AM_AccountCode" readonly />

                </div>
            </div>
            <div class="col-lg-3">
                <div class="form-group">
                    <label for="ddlAccountDesc">Account Desc:</label>
                    <input id="ddlAccountDesc" name="ddlAccountDesc" class="form-control" value="@Model.AM_AccDescription" readonly />

                </div>
            </div>
            <div class="col-lg-3">
                <div class="form-group">
                    <label for="txtOpeningBalance">Opening Balance:</label>
                    <input id="txtOpeningBalance" name="txtOpeningBalance" class="form-control numeric" value="@Model.AM_OpeningBalance" />
                </div>
            </div>
            <div class="col-lg-3">
                <div class="form-group">
                    <label for="ddlOpeningType">Type:</label>
                    <select id="ddlOpeningType" name="ddlOpeningType" class="form-control">
                        @if (Model.AM_OPeningType != null)
                        {
                            if (Model.AM_OPeningType.Trim() == "C")
                            {
                                <option value="C" selected="selected">Credit</option>
                                <option value="D">Debit</option>

                            }
                            else
                            {
                                <option value="D" selected="selected">Debit</option>
                                <option value="C">Credit</option>

                            }
                        }
                        else
                        {
                            <option value="C">Credit</option>
                            <option value="D">Debit</option>
                        }


                    </select>
                </div>
            </div>

        </div>



        <div class="row">
            <div class="col-lg-6">
                <div class="form-group">
                    <input type="hidden" id="hdnValidation" name="hdnValidation" value="@ViewBag.MessageId" />
                    <div id="divValidation"></div>
                    <div id="divMessage" style="text-align:right;margin-top:25px;font-size: 16px;color: green;font-weight: bold;text-transform: capitalize">@ViewBag.Message</div>
                </div>
            </div>


        </div>
        <hr />
        <hr />
        <div class="row mt-4">
            <a href="/AccountMaster/OpeningBalanceMasterList">
                <img src="~/Logo/back.png" width="20" height="20" />
                Back To List
            </a>

            <div class="row mt-4">
                <div class="col-12 text-end">
                    <button type="button" id="btnSubmit" class="btn btn-animated btn-gradient me-2" onclick="SaveData();">
                        <i class="bi bi-save"></i> Save
                    </button>
                    <button type="button" id="btnReset" class="btn btn-animated btn-outline-secondary" onclick="location.reload();">
                        <i class="bi bi-arrow-clockwise"></i> Reset
                    </button>
                </div>
            </div>

        </div>


    }
</div>

<script type="text/javascript">
