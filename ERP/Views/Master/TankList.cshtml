@model BObject.TankMaster_TM
@{ ViewBag.Title = "Tank List"; }
<h2 style="background-color: aliceblue; text-align: center;">@ViewBag.Title</h2>
@if ((bool)Session["CanAdd"] == true)
{
<a href="Tank" style="text-decoration:none;" class="btn btn-primary">NEW TANK</a>}

@if ((bool)Session["CanView"] == true)
{
<div class="row">
    <div class="col-sm-12 col-xl-12 col-md-12 table-responsive">
        <table id="table" data-toggle="table" data-pagination="true" data-search="true" data-show-pagination-switch="true" data-show-refresh="true" data-key-events="true" data-show-toggle="true" data-resizable="true" data-cookie="true">
            <thead>
                <tr>
                    <th data-checkbox="true"></th>
                    <th>Sl</th>
                    <th>Code</th>
                    <th>Name</th>
                    <th>Ltr</th>
                    <th>Rate</th>
                    <th>Edit</th>
                    <th>Delete</th>
                </tr>
            </thead>
            <tbody>
                @{ int i = 1; }
                @foreach (var item in Model.TankList)
                {
<tr>
    <td></td>
    <td>@i</td>
    <td>@item.TM_TankCode</td>
    <td>@item.TM_TankName</td>
    <td>@item.TM_Lt</td>
    <td>@item.TM_Rate</td>
    <td>
        <a href="/Master/Tank/@item.TM_ID" style="text-decoration:none;">
            <img src="~/Logo/Edit.png" width="30" height="30" title="Edit" />
        </a>
    </td>
    <td>
        <a href="javascript:void(0)" onclick="DeleteTank(@item.TM_ID);" style="text-decoration:none;">
            <img src="~/Logo/Delete.png" width="30" height="30" title="Delete" />
        </a>
    </td>
</tr>                    i = i + 1;
                }
            </tbody>
        </table>
    </div>
</div> }
            else
            {
<div class="alert-danger">
    <h3>You Are Not Authorize....................!</h3>
</div>}

@Scripts.Render("~/bundles/jquery")
<script src="~/Scripts/data-table/bootstrap-table.js"></script>
<script src="~/Scripts/AppScript/Tank.js"></script>