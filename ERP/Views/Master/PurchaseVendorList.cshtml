@model BObject.PurchaseVendorMaster_PVM
@{
    ViewBag.Title = "PurchaseVendorList";
}

<h2 style="background-color: aliceblue; text-align: center;">@ViewBag.Title</h2>
@if ((bool)Session["CanAdd"] == true)
{
<a href="/Master/PurchaseVendor" style="text-decoration:none;" class="btn btn-primary">NEW PURCHESEVENDOR</a>
}
<hr />

@if ((bool)Session["CanView"] == true)
{
<div class="row">
    <div class="col-sm-12 col-xl-12 col-md-12 table-responsive">
        <table id="table" data-toggle="table" data-pagination="true" data-search="true" data-show-pagination-switch="true" data-show-refresh="true" data-key-events="true" data-show-toggle="true" data-resizable="true" data-cookie="true" data-cookie-id-table="saveId" data-show-export="true" data-click-to-select="true" data-toolbar="#toolbar">
            <thead>
                <tr>
                    <th data-checkbox="true"></th>
                    <th>Sl.</th>
                    <th>VendorCode</th>
                    <th>Vandor Name</th>
                    <th>Address1</th>
                    <th>Address2</th>
                    <th>City</th>
                    <th>PIN NO.</th>
                    <th>FAX.</th>
                    <th>Phone No</th>
                    <th>Email</th>
                    <th>Edit</th>
                    <th>Delete</th>
                </tr>
            </thead>
            <tbody>
                @{
                    int i = 1;
                }
                @foreach (var item in Model.ListVendor)
                {
                    <tr>
                        <td></td>
                        <td>@i</td>
                        <td>@item.PVM_VendorCode</td>
                        <td>@item.PVM_VendorName</td>
                        <td>@item.PVM_Address1</td>
                        <td>@item.PVM_Address2</td>
                        <td>@item.PVM_City</td>
                        <td>@item.PVM_PIN</td>
                        <td>@item.PVM_FaxNo</td>
                        <td>@item.PVM_Phone</td>
                        <td>@item.PVM_Email</td>


                        <td>
                            <a href="/Master/PurchaseVendor/@item.PVM_VendorID" style="text-decoration:none;">
                                <img src="~/Logo/Edit.png" width="30" height="30" title="Edit" />
                            </a>
                        </td>
                        <td>
                            <a href="javascript:void(0)" onclick="DeleteVendor(@item.PVM_VendorID);" style="text-decoration:none;">
                                <img src="~/Logo/Delete.png" width="30" height="30" title="Delete" />
                            </a>
                        </td>
                    </tr>
                    i = i + 1;
                }

            </tbody>
        </table>
    </div>
</div>
                    }
                    else
                    {
                        <div class="alert-danger">
                            <h3>You Are Not Authorize....................!</h3>
                        </div>
                    }
@Scripts.Render("~/bundles/jquery")
<script src="~/Scripts/data-table/bootstrap-table.js"></script>

<script src="~/Scripts/AppScript/PurcheseVendor.js"></script>