@model BObject.AreaMaster_AM
@{
    ViewBag.Title = "Area";
}

<h2 style="background-color: aliceblue; text-align: center;">@ViewBag.Title</h2>

@using (Html.BeginForm("Area", "Master", new { ReturnUrl = ViewBag.ReturnUrl }, FormMethod.Post))
{
    @Html.HiddenFor(m => m.AM_AreaID)
    <div class="row">
        <div class="col-md-3">
            @*@Html.LabelFor(m => m.CM_ID, new { @class = "form-label" })
                @Html.DropDownList("CM_ID", null, "Select Company", new { @class = "form-control", required = "required" })*@
        </div>
        <div class="col-md-3">
            @Html.LabelFor(m => m.AM_AreaCode, new { @class = "form-label" })<span style="color:red">*</span>
            @Html.TextBoxFor(m => m.AM_AreaCode, new { @class = "form-control", @placeholder = "Area Code(Number only)" })
        </div>
        <div class="col-md-3">
            @Html.LabelFor(m => m.AM_AreaName, new { @class = "form-label" })<span style="color:red">*</span>
            @Html.TextBoxFor(m => m.AM_AreaName, new { @class = "form-control", @placeholder = "Area Name" })
        </div>
        <div class="col-md-3">

        </div>
    </div>





    <br />
    <div class="row">
        <div class="col-md-8">
            <a href="/Master/AreaList">
                <img src="~/Logo/back.png" width="20" height="20" />
                Back To List
            </a>
        </div>
        <div class="col-md-4">
            <button type="button" onclick="Refresh();" class="btn btn-info">REFRESH</button>
            @if (ViewBag.Button == "SUBMIT")
            {
                if ((bool)Session["CanSubmit"] == true)
                {
                    <button type="button" onclick="BtnSaveUpdate();" class="btn btn-primary">@ViewBag.Button</button>
                }
                else
                {
                    <button type="button" class="btn btn-primary">Submit Not Authorized</button>
                }
            }
            @if (ViewBag.Button == "UPDATE")
            {
                if ((bool)Session["CanUpdate"] == true)
                {
                    <button type="button" onclick="BtnSaveUpdate();" class="btn btn-primary">@ViewBag.Button</button>
                }
                else
                {
                    <button type="button" class="btn btn-primary">Update Not Authorized</button>
                }
            }

        </div>
    </div>
}

@Scripts.Render("~/bundles/jquery")
<script src="~/Scripts/AppScript/Area.js"></script>
