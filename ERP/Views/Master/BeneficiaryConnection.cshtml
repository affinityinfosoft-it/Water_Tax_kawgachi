@model BObject.PartyMaster_PM
@{
    ViewBag.Title = "Beneficiary Connection";
}
<style>
    .select2-container .select2-selection--single {
        height: 34px !important;
    }

    .select2-container--default .select2-selection--single {
        border: 1px solid #ccc !important;
        border-radius: 0px !important;
    }
</style>
<h2 style="background-color: aliceblue; text-align: center;">@ViewBag.Title</h2>

@using (Html.BeginForm("BeneficiaryConnection", "Master", new { ReturnUrl = ViewBag.ReturnUrl }, FormMethod.Post))
{
    @Html.HiddenFor(m => m.PM_PartyId)

    <div class="row">
        <div class="col-md-3">
            @Html.LabelFor(m => m.PM_PartyCode, new { @class = "form-label" })<span style="color:red">*</span>
            @Html.TextBoxFor(m => m.PM_PartyCode, new { @class = "form-control", @placeholder = "Party Code" } )
        </div>
        <div class="col-md-3">
            @Html.LabelFor(m => m.PM_RegDate, new { @class = "form-label" })<span style="color:red">*</span>
            @Html.TextBoxFor(m => m.PM_RegDate, "{0:yyyy-MM-dd}", new { @type = "date", @class = "form-control", @placeholder = "Reg Date" })
        </div>
        <div class="col-md-3">
            @Html.LabelFor(m => m.PM_PartyName, new { @class = "form-label" })<span style="color:red">*</span>
            @Html.TextBoxFor(m => m.PM_PartyName, new { @class = "form-control", @placeholder = "Consumer Name" })
        </div>
        <div class="col-md-3">
            @Html.LabelFor(m => m.PM_FHName, new { @class = "form-label" })<span style="color:red">*</span>
            @Html.TextBoxFor(m => m.PM_FHName, new { @class = "form-control", @placeholder = "Father / Husband Name" })
        </div>
    </div>
    <div class="row">
        <div class="col-md-3">
            @Html.LabelFor(m => m.AM_AreaID, new { @class = "form-label" })<span style="color:red">*</span>
            @Html.DropDownList("AM_AreaID", null, "Select Area", new { @class = "form-control select2" })
        </div>
        <div class="col-md-3">
            @Html.LabelFor(m => m.PM_ParaId, new { @class = "form-label" })<span style="color:red">*</span>
            @Html.DropDownList("PM_ParaId", null, "Select Para", new { @class = "form-control select2" })
        </div>
        <div class="col-md-3">
            @Html.LabelFor(m => m.PM_Address, new { @class = "form-label" })<span style="color:red">*</span>
            @Html.TextBoxFor(m => m.PM_Address, new { @class = "form-control", @placeholder = "Address" })
        </div>
        <div class="col-md-3">
            @Html.LabelFor(m => m.PM_City, new { @class = "form-label" })<span style="color:red">*</span>
            @Html.TextBoxFor(m => m.PM_City, new { @class = "form-control", @placeholder = "City" })
        </div>
    </div>
    <div class="row">
        <div class="col-md-3">
            @Html.LabelFor(m => m.PM_PIN, new { @class = "form-label" })<span style="color:red">*</span>
            @Html.TextBoxFor(m => m.PM_PIN, new { @class = "form-control", @placeholder = "Pin" })
        </div>
        <div class="col-md-3">
            @Html.LabelFor(m => m.PM_PhoneNo, new { @class = "form-label" })<span style="color:red">*</span>
            @Html.TextBoxFor(m => m.PM_PhoneNo, new { @class = "form-control", @placeholder = "Aadhaar No" })
        </div>
        <div class="col-md-3">
            @Html.LabelFor(m => m.PM_MobNo, new { @class = "form-label" })<span style="color:red">*</span>
            @Html.TextBoxFor(m => m.PM_MobNo, new { @class = "form-control", @placeholder = "Mobile No" })
        </div>
        <div class="col-md-3">
            @Html.LabelFor(m => m.PM_BFAmount, new { @class = "form-label" })<span style="color:red">*</span>
            @Html.TextBoxFor(m => m.PM_BFAmount, new { @class = "form-control", @placeholder = "Beneficiary Amt", disabled = "true" })
        </div>
    </div>
    <div class="row">
	    <div class="col-md-3">
        </div>
        <div class="col-md-3">
            @Html.LabelFor(m => m.PM_PaidAmt, new { @class = "form-label" })<span style="color:red">*</span>
            @if (Model.PM_PartyId > 0)
            {
                @Html.TextBoxFor(m => m.PM_PaidAmt, new { @class = "form-control", @placeholder = "Paid Amt", disabled = "true", @onkeyup = "PaidAmountOnKeyUp(" + Model.PM_BFAmount + ");" })
            }
            else
            {
                @Html.TextBoxFor(m => m.PM_PaidAmt, new { @class = "form-control", @placeholder = "Paid Amt", @onkeyup = "PaidAmountOnKeyUp(" + Model.PM_BFAmount + ");" })
            }
        </div>
        <div class="col-md-3">
            @Html.LabelFor(m => m.PM_DueAmt, new { @class = "form-label" })
            @Html.TextBoxFor(m => m.PM_DueAmt, new { @class = "form-control", @placeholder = "Due Amt", disabled = "true" })
        </div>
    </div>
    <br />
    <div class="row">
        <div class="col-md-8">
            <a href="/Master/BeneficiaryConnectionList">
                <img src="~/Logo/back.png" width="20" height="20" />
                Back To List
            </a>
        </div>
        <div class="col-md-4">
            <button type="button" onclick="Refresh();" class="btn btn-info">REFRESH</button>

            @if (ViewBag.Button == "SUBMIT")
            {
                if ((bool)Session["CanSubmit"] == true)
                {
                    <button type="button" onclick="BtnSaveUpdate();" class="btn btn-primary">@ViewBag.Button</button>
                }
                else
                {
                    <button type="button" class="btn btn-primary">Submit Not Authorized</button>
                }
            }

            @if (ViewBag.Button == "UPDATE")
            {
                if ((bool)Session["CanUpdate"] == true)
                {
                    <button type="button" onclick="BtnSaveUpdate();" class="btn btn-primary">@ViewBag.Button</button>
                }
                else
                {
                    <button type="button" class="btn btn-primary">Update Not Authorized</button>
                }
            }


        </div>
    </div>
}
@Scripts.Render("~/bundles/jquery")
<script src="https://cdnjs.cloudflare.com/ajax/libs/select2/4.0.6-rc.0/js/select2.min.js"></script>
<script>
    $('.select2').select2();
</script>
<script src="~/Scripts/AppScript/BeneficeryConnection.js"></script>