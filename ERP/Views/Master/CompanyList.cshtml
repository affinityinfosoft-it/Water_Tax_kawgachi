@model BObject.company
@{
    ViewBag.Title = "Company List";
}
<h2 style="background-color: aliceblue; text-align: center;">@ViewBag.Title</h2>
@if ((bool)Session["CanAdd"] == true)
{
    <a href="Company" style="text-decoration:none;" class="btn btn-primary">NEW COMPANY</a>
}
<hr />
@if ((bool)Session["CanView"] == true)
{
    <div class="row">
        <div class="col-sm-12 col-xl-12 col-md-12 table-responsive">
            <table id="table" data-toggle="table" data-pagination="true" data-search="true" data-show-pagination-switch="true" data-show-refresh="true" data-key-events="true" data-show-toggle="true" data-resizable="true" data-cookie="true" data-cookie-id-table="saveId" data-show-export="true" data-click-to-select="true" data-toolbar="#toolbar">
                <thead>
                    <tr>
                        <th data-checkbox="true"></th>
                        <th>Sl.</th>
                        <th>Code</th>
                        <th>Company Name</th>
                        @*<th>City</th>
                        <th>Pin</th>*@
                        <th>Contact No</th>
                        <th>Address</th>
                        <th>Business Type</th>
                        <th>Entry Date</th>
                        @*<th>GST No</th>
                        <th>Description</th>*@
                        <th>Services</th>
                        @*<th>Permited</th>*@
                        @*<th>Founder</th>*@
                        <th>Logo</th>
                        <th>Edit</th>
                        <th>Delete</th>
                    </tr>
                </thead>
                <tbody>
                    @{
                        int i = 1;
                    }
                    @foreach (var item in Model.CompanyList)
                    {
                        <tr>
                            <td></td>
                            <td>@i</td>
                            <td>@item.code</td>
                            <td>@item.name</td>
                            @*<td>@item.city</td>
                            <td>@item.pin</td>*@
                            <td>@item.phoneno</td>
                            <td>@item.address</td>
                            <td>@item.puser</td>
                            <td>@item.dt_of_entry.ToShortDateString()</td>
                            @*<td>@item.invbill_prefix</td>
                            <td>@item.ho</td>*@
                            <td>@item.ipd_pref</td>
                            @*<td>@item.opd_pref</td>*@
                            @*<td>@item.opdinv_pref</td>*@
                            <td> <a href="@item.logo" target="_blank"><img src="~/Logo/arrow-down-circle.svg" /></a></td>
                            <td>
                                <a href="/Master/Company/@item.CM_ID" style="text-decoration:none;">
                                    <img src="~/Logo/Edit.png" width="30" height="30" title="Edit" />
                                </a>
                            </td>
                            <td>
                                <a href="javascript:void(0)" onclick="DeleteCompany(@item.CM_ID);" style="text-decoration:none;">
                                    <img src="~/Logo/Delete.png" width="30" height="30" title="Delete" />
                                </a>
                            </td>
                        </tr>
                        i = i + 1;
                    }

                </tbody>
            </table>
        </div>
    </div>
}
else
{
    <div class="alert-danger">
        <h3>You Are Not Authorize....................!</h3>
    </div>
}
@Scripts.Render("~/bundles/jquery")
<script src="~/Scripts/data-table/bootstrap-table.js"></script>
<script src="~/Scripts/AppScript/Company.js"></script>
