@model BObject.PartyLedger_PL
@{
    ViewBag.Title = "Consumer Payment";
}
<style>
    .select2-container .select2-selection--single {
        height: 34px !important;
    }

    .select2-container--default .select2-selection--single {
        border: 1px solid #ccc !important;
        border-radius: 0px !important;
    }
</style>
<h2 style="background-color: aliceblue; text-align: center;">@ViewBag.Title</h2>
@using (Html.BeginForm("ConsumerPayment", "Transaction", new { ReturnUrl = ViewBag.ReturnUrl }, FormMethod.Post))
{
    @Html.HiddenFor(m => m.PL_Id)
    <div class="row">
        <div class="col-md-3">
        </div>
        <div class="col-md-3">
            <label>Rcpt No</label>
            @Html.TextBoxFor(m => m.PL_RcptNo, new { @class = "form-control", @placeholder = "Rcpt No", @readonly = "readonly" })
        </div>
        <div class="col-md-3">
            <label>Rcpt Date</label>
            @Html.TextBoxFor(m => m.PL_RcptDate, "{0:yyyy-MM-dd}", new { @class = "form-control", @placeholder = "Rcpt Date", @type = "date" })
        </div>
    </div>
    <hr />
    <div class="row">
        <div class="col-md-3">
            <label>Consumer Id</label><span style="color:red;">*</span>
            @Html.TextBoxFor(m => m.PL_PartyCode, new { @class = "form-control", @placeholder = "Consumer Id", @onchange = "SearchByPartyCode();" })
        </div>
        <div class="col-md-3">
            <label>Party Name</label>
            @Html.DropDownList("PM_PartyCode", null, "Select Consumer", new { @class = "form-control select2 ", required = "required", @onchange = "SearchByPartyName();" })
        </div>
        <div class="col-md-3">
            <label>Consumer Father/Husband Name</label>
            @Html.TextBoxFor(m => m.PM_FHName, new { @class = "form-control", @placeholder = "Consumer F/H Name", @readonly = "readonly" })
        </div>
        <div class="col-md-3">
            <label>Area Name</label>
            @Html.TextBoxFor(m => m.AM_AreaName, new { @class = "form-control", @placeholder = "Area Name", @readonly = "readonly" })
        </div>
    </div>
    <div class="row">
	    <div class="col-md-3">
        </div>
        <div class="col-md-3">
            <label>Para</label>
            @Html.TextBoxFor(m => m.PM_ParaName, new { @class = "form-control", @placeholder = "Para", @readonly = "readonly" })
        </div>
        <div class="col-md-3">
            <label>Contact No</label>
            @Html.TextBoxFor(m => m.PM_MobNo, new { @class = "form-control", @placeholder = "Contact No", @readonly = "readonly" })
        </div>
    </div>

    <hr />
    <div class="row">
        <div class="col-md-12">
            <table class="table" border="1" id="table" style="padding: 0rem 0rem;">
                <thead>
                    <tr>
                        <th><input type="checkbox" class="form-check-input" id="chkDue" /></th>
                        <th>Bill No</th>
                        <th>Bill Date</th>
                        <th>OS Amount</th>
                        <th>Paid Amount</th>
                        @*<th>Discount</th>*@

                    </tr>
                </thead>
                <tbody>
                    @if (Model.PartyLadgerList != null)
                    {
                        foreach (var i in Model.PartyLadgerList)
                        {
                            int PaidAmt = Convert.ToInt32(@i.PL_PaidAmount);
                            int Due = Convert.ToInt32(ViewBag.DueAmt);
                            int TotalDue = PaidAmt + Due;
                    <tr>
                        <td><input class="form-check-input" type="checkbox" onClick="ChkOnClick('@i.PL_BillNo')" id="chk'+@i.PL_BillNo+'" value="@i.PL_BillNo" /></td>
                        <td><input type="text" id="BType+@i.PL_BillNo" value="@i.PL_BType" onclick="" /></td>
                        <td><input type="date" id="bill+@i.PL_BillNo" value="@i.PL_BillNo" /></td>
                        <td><input type="text" id="Bdate+@i.PL_BillNo" value="@i.PL_BillDates" /></td>
                        <td><input type="text" id="BillAmt+@i.PL_BillNo" value="@i.PL_PaidAmount" /></td>
                        <td><input type="text" id="PaidAmt+@i.PL_BillNo" onkeyup="txtPL_PaidAmountOnKey();" value="@i.PL_PaidAmount" /></td>
                        @*<td><input type="text" id="Dist+@i.PL_BillNo" onkeyup="txtDiscountOnKey();" value="0" /></td>*@
                    </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
    <hr />
    <div class="row">
        <div class="col-md-3">
            <label>Payment Mode</label>
            <div class="">
                Cash
                @Html.RadioButtonFor(m => m.PL_RcptType, "CA", new { @class = "form-check-input" ,@checked = "checked" })
                &nbsp; &nbsp;
                Bank
                @Html.RadioButtonFor(m => m.PL_RcptType, "BA", new { @class = "form-check-input" })
            </div>
        </div>
        <div class="col-md-3">
            <label>Cheque No</label>
            @Html.TextBoxFor(m => m.PL_ChqNo, new { @class = "form-control", @placeholder = "Cheque No" })
        </div>
        <div class="col-md-3">
            <label>Cheque Date</label>

            @Html.TextBoxFor(m => m.PL_ChqDate, "{0:yyyy-MM-dd}", new { @class = "form-control", @placeholder = "Cheque Date", @type = "date" })
        </div>
        <div class="col-md-3">
            <label>Bank Name</label>
            @Html.TextBoxFor(m => m.PL_Bank, new { @class = "form-control", @placeholder = "Bank Name" })
        </div>

    </div>
    <div class="row">
        <div class="col-md-6">
            <br />
            <a href="/Transaction/ConsumerPaymentList">
                <img src="~/Logo/back.png" width="20" height="20" />
                Back To List
            </a>
        </div>
        <div class="col-md-2">
            <label>Alocated Amount</label>
            @Html.TextBoxFor(m => m.PL_PaidAmount, new { @class = "form-control", @placeholder = "Bank Name", @readonly = "readonly" })
        </div>
        <div class="col-md-1">
        </div>
        <div class="col-md-3">
            <br />
            <button type="button" onclick="Refresh();" class="btn btn-info">REFRESH</button>
            <button type="button" id="btnInsUp" onclick="BtnSaveUpdate();" class="btn btn-primary">@ViewBag.Button</button>
        </div>
    </div>
}
@Scripts.Render("~/bundles/jquery")
<link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
<script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>

<script>
    $('.select2').select2();
    minimumInputLength: 3
</script>

<script src="~/Scripts/AppScript/ConsumerPayment.js"></script>