@model BObject.Project
@{
    ViewBag.Title = "Project";
}
<h2 style="background-color: aliceblue; text-align: center;">@ViewBag.Title</h2>
@using (Html.BeginForm("Menu", "Admin", new { ReturnUrl = ViewBag.ReturnUrl }, FormMethod.Post))
{
    @Html.HiddenFor(m => m.ProjectId)
    <div class="row">
        <div class="col-md-3">
            <label>Project Name</label><span style="color:red;">*</span>
            @*@Html.LabelFor(m => m.ProjectName, new { @class = "form-label" })<span style="color:red;">*</span>*@
            @Html.TextBoxFor(m => m.ProjectName, new { @class = "form-control", @placeholder = "Project Name" })
        </div>
        <div class="col-md-3">
            <label>Project Short Name</label><span style="color:red;">*</span>
            @*@Html.LabelFor(m => m.ProjectShortName, new { @class = "form-label" })<span style="color:red;">*</span>*@
            @Html.TextBoxFor(m => m.ProjectShortName, new { @class = "form-control", @placeholder = "Project Short Name" })
        </div>
        <div class="col-md-3">
            <label>Project Code</label><span style="color:red;">*</span>
            @*@Html.LabelFor(m => m.Code, new { @class = "form-label" })<span style="color:red;">*</span>*@
            @Html.TextBoxFor(m => m.Code, new { @class = "form-control", @placeholder = "Project Code" })
        </div>
        <div class="col-md-3">
            @Html.LabelFor(m => m.Email, new { @class = "form-label" })<span style="color:red;">*</span>
            @Html.TextBoxFor(m => m.Email, new { @class = "form-control", @placeholder = "Email" })
        </div>
    </div>
    <br />
    <div class="row">
        <div class="col-md-3">
            <label>Phone No</label><span style="color:red;">*</span>
            @*@Html.LabelFor(m => m.PhNo, new { @class = "form-label" })<span style="color:red;">*</span>*@
            @Html.TextBoxFor(m => m.PhNo, new { @class = "form-control", @placeholder = "Ph No" })
        </div>
        <div class="col-md-3">
            <label>TelePhone </label><span style="color:red;">*</span>
            @*@Html.LabelFor(m => m.TelPhNo, new { @class = "form-label" })*@
            @Html.TextBoxFor(m => m.TelPhNo, new { @class = "form-control", @placeholder = "Tel Ph No" })
        </div>
        <div class="col-md-3">
            <label>Web Site</label><span style="color:red;">*</span>
            @*@Html.LabelFor(m => m.WebSite, new { @class = "form-label" })*@
            @Html.TextBoxFor(m => m.WebSite, new { @class = "form-control", @placeholder = "Web Site" })
        </div>
        <div class="col-md-3">
            <label>GST No</label><span style="color:red;">*</span>
            @*@Html.LabelFor(m => m.GST, new { @class = "form-label" })*@
            @Html.TextBoxFor(m => m.GST, new { @class = "form-control", @placeholder = "GST No" })
        </div>

    </div>
    <br />
    <div class="row">
        <div class="col-md-3">
            <label>Pin</label><span style="color:red;">*</span>
            @*@Html.LabelFor(m => m.Pin, new { @class = "form-label" })*@
            @Html.TextBoxFor(m => m.Pin, new { @class = "form-control", @placeholder = "Pin No" })
        </div>
        <div class="col-md-3">
            <label>Country</label><span style="color:red;">*</span>
            @*@Html.LabelFor(m => m.CountryId, new { @class = "form-label" })*@
            @Html.TextBoxFor(m => m.CountryId, new { @class = "form-control", @placeholder = "Country" })
        </div>
        <div class="col-md-3">
            <label>State</label><span style="color:red;">*</span>
            @*@Html.LabelFor(m => m.StateId, new { @class = "form-label" })*@
            @Html.TextBoxFor(m => m.StateId, new { @class = "form-control", @placeholder = "State" })
        </div>
        <div class="col-md-3">
            <label>City</label><span style="color:red;">*</span>
            @*@Html.LabelFor(m => m.CityId, new { @class = "form-label" })*@
            @Html.TextBoxFor(m => m.CityId, new { @class = "form-control", @placeholder = "City" })
        </div>
    </div>
    <br />
    <div class="row">
        <div class="col-md-6">
            @Html.LabelFor(m => m.Address, new { @class = "form-label" })<span style="color:red;">*</span>
            @Html.TextAreaFor(m => m.Address, new { @class = "form-control", @type = "number", @placeholder = "Address", @style = "max-width:99%" })
        </div>
        <div class="col-md-3">
            <label>Image</label><span style="color:red;">*</span>
            @*@Html.LabelFor(m => m.Img, new { @class = "form-label" })*@
            @Html.TextBoxFor(m => m.Img, new { @class = "form-control", @type = "file" })
            <a href="javascript(void)"><img src="~/Logo/arrow-down-circle.svg" /></a>
        </div>
        <div class="col-md-3">
            <label>Preview</label><br />
            <img id="blah" src="#" alt="" width="80" height="80" style="border:solid" />
        </div>
    </div>
    <br />
    <div class="row">
        <div class="col-md-10">
            @*<a href="/Admin/MenuList">
                <img src="~/Logo/back.png" width="20" height="20" />
                Back To List
            </a>*@
        </div>
        <div class="col-md-2">
            <button type="submit" class="btn btn-info">REFRESH</button>
            <button type="submit" class="btn btn-primary">@ViewBag.Button</button>
        </div>
    </div>
}
@Scripts.Render("~/bundles/jquery")

<script>
    //$('.select2').select2();
    function readURL(input) {
        if (input.files && input.files[0]) {
            var reader = new FileReader();

            reader.onload = function (e) {
                $('#blah').attr('src', e.target.result);
            }
            reader.readAsDataURL(input.files[0]);
        }
    }

    $("#Img").change(function () {
        readURL(this);
    });
</script>
@if (TempData.ContainsKey("Message"))
{
    <script type="text/javascript">
        //success / error / warning / info
        toastr.warning("@TempData["Message"]")
    </script>
}
